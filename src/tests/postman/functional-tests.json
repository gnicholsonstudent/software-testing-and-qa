              "value": "X-Api-Key",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"label\": \"Test label\",\r\n  \"active\": true,\r\n  \"derivesFrom\": null\r\n}",
          "options": {
